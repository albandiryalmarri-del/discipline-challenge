function openPanel(key) {
  const d = data[key]; if(!d) return;
  let h = `<div class="panel-time">${d.time}</div><div class="panel-title">${d.title}</div><div class="panel-emoji-row">${d.emoji}</div>`;
  h += `<div class="sblock"><h3>📜 التاريخ والقصة</h3><p>${d.history.replace(/\n/g,'<br>')}</p></div>`;
  if(d.details) h += `<div class="sblock"><h3>ℹ️ ماذا تتوقعين</h3><p>${d.details}</p></div>`;
  if(d.tips&&d.tips.length) h += `<div class="sblock"><h3>💡 نصائح</h3>${d.tips.map(t=>`<div class="tip-row"><span class="tip-icon">${t.icon}</span><span class="tip-text">${t.text}</span></div>`).join('')}</div>`;
  if(d.do&&d.do.length) h += `<div class="sblock"><h3>✅ اعمليها</h3><ul>${d.do.map(x=>`<li>${x}</li>`).join('')}</ul></div>`;
  if(d.buy&&d.buy.length) h += `<div class="sblock"><h3>🛒 وش تشترين/تطلبين</h3>${d.buy.map(b=>`<span class="tag">${b}</span>`).join('')}</div>`;
  if(d.avoid) h += `<div class="sblock" style="border-color:rgba(232,93,58,0.3)"><h3 style="color:#e85d3a">⚠️ انتبهي</h3><p>${d.avoid}</p></div>`;
  document.getElementById('panel-content').innerHTML = h;
  document.getElementById('overlay').classList.add('open');
  document.getElementById('panel').scrollTop = 0;
}
function closePanelBg(e){ if(e.target===document.getElementById('overlay')) document.getElementById('overlay').classList.remove('open'); }
function closePanelBtn(){ document.getElementById('overlay').classList.remove('open'); }
</script>

