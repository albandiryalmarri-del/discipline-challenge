<!DOCTYPE html>

<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>خريطة كنز Poole 🗺️</title>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700;900&family=Cinzel:wght@700&display=swap" rel="stylesheet">
<style>
* { margin:0; padding:0; box-sizing:border-box; }

body {
background: #1a0e05;
font-family: ‘Tajawal’, sans-serif;
min-height: 100vh;
overflow-x: hidden;
}

.page {
max-width: 520px;
margin: 0 auto;
padding: 20px 16px 80px;
}

/* ═══ TITLE ═══ */
.title-wrap {
text-align: center;
padding: 24px 0 10px;
animation: fadeIn 0.8s ease both;
}
.title-wrap .scroll-icon {
font-size: 36px;
display: block;
animation: sway 4s ease-in-out infinite;
}
@keyframes sway { 0%,100%{transform:rotate(-5deg)} 50%{transform:rotate(5deg)} }
.title-wrap h1 {
font-family: ‘Cinzel’, serif;
font-size: 20px;
color: #d4a843;
letter-spacing: 3px;
text-shadow: 0 0 20px rgba(212,168,67,0.5);
margin: 6px 0 4px;
}
.title-wrap p { font-size: 11px; color: #a07840; letter-spacing: 2px; }

/* ═══ MAP ═══ */
.map-container {
position: relative;
margin: 16px 0;
border-radius: 18px;
overflow: hidden;
border: 3px solid #8b6020;
box-shadow: 0 0 0 5px rgba(139,96,32,0.2), 0 16px 50px rgba(0,0,0,0.6);
animation: fadeIn 0.8s 0.2s ease both;
}
.map-svg { width:100%; display:block; }

.pin { cursor:pointer; transition:transform 0.2s; transform-origin:center bottom; }
.pin:hover { transform:scale(1.2); }
.pin:active { transform:scale(0.95); }

.hint {
text-align:center; font-size:12px; color:#6b4f30;
margin: 6px 0 14px;
animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse { 0%,100%{opacity:0.5} 50%{opacity:1} }

/* ═══ SECTION DIVIDER ═══ */
.section-sep {
display: flex;
align-items: center;
gap: 12px;
margin: 28px 0 18px;
}
.section-sep .line {
flex:1;
height: 1px;
background: linear-gradient(to left, transparent, #8b6020);
}
.section-sep .line.r {
background: linear-gradient(to right, transparent, #8b6020);
}
.section-sep span {
font-size: 11px;
color: #d4a843;
letter-spacing: 2px;
text-transform: uppercase;
white-space: nowrap;
}

/* ═══ PROGRESS ═══ */
.progress-wrap {
background: rgba(255,255,255,0.06);
border-radius: 50px;
height: 6px;
margin-bottom: 6px;
overflow: hidden;
}
.progress-bar {
height:100%;
background: linear-gradient(to left, #d4a843, #8b6020);
border-radius:50px;
transition: width 0.5s cubic-bezier(.4,0,.2,1);
width:0%;
}
.progress-text {
font-size:11px; color:#8b6020;
text-align:center; margin-bottom:16px;
}

/* ═══ CHECK ITEMS ═══ */
.check-item {
display:flex;
align-items:flex-start;
gap:12px;
padding: 13px 14px;
border-radius: 14px;
margin-bottom: 7px;
cursor: pointer;
border: 1px solid rgba(139,96,32,0.25);
background: rgba(212,168,67,0.04);
transition: all 0.25s ease;
-webkit-tap-highlight-color: transparent;
user-select: none;
animation: fadeUp 0.4s ease both;
}
.check-item:hover {
background: rgba(212,168,67,0.08);
border-color: rgba(212,168,67,0.35);
transform: translateX(-2px);
}
.check-item.checked {
background: rgba(26,122,50,0.1);
border-color: rgba(26,122,50,0.3);
opacity: 0.65;
}
.check-item.checked .ci-title {
text-decoration: line-through;
color: #6b8060;
}
.check-item.checked .ci-time { color: #4caf50; opacity:0.7; }

@keyframes fadeUp {
from { opacity:0; transform:translateY(10px); }
to { opacity:1; transform:translateY(0); }
}

/* Checkbox circle */
.ci-box {
width:26px; height:26px; min-width:26px;
border-radius:50%;
border: 2px solid rgba(212,168,67,0.35);
display:flex; align-items:center; justify-content:center;
transition: all 0.3s cubic-bezier(.4,0,.2,1);
margin-top: 1px;
background: rgba(212,168,67,0.05);
}
.check-item.checked .ci-box {
background: #2d7a30;
border-color: #2d7a30;
transform: scale(1.08);
}
.ci-box svg { opacity:0; transform:scale(0); transition:all 0.2s ease; }
.check-item.checked .ci-box svg { opacity:1; transform:scale(1); }

/* Content */
.ci-content { flex:1; }
.ci-row { display:flex; align-items:center; gap:8px; margin-bottom:2px; }
.ci-emoji { font-size:15px; }
.ci-time { font-size:10px; color:#d4a843; font-weight:700; letter-spacing:1px; }
.ci-star { font-size:11px; }
.ci-title { font-size:15px; font-weight:700; color:#f0e0b0; transition:color 0.25s; }
.ci-sub { font-size:12px; color:#8b6a3a; margin-top:2px; line-height:1.5; }

/* Info button */
.ci-info {
background: rgba(212,168,67,0.1);
border: 1px solid rgba(212,168,67,0.2);
color: #d4a843;
font-size:13px;
width:28px; height:28px;
border-radius:50%;
display:flex; align-items:center; justify-content:center;
cursor:pointer;
flex-shrink:0;
margin-top:2px;
transition: all 0.2s;
}
.ci-info:hover { background:rgba(212,168,67,0.2); }

/* Group label */
.group-label {
font-size:10px; color:#8b6020; letter-spacing:2px;
text-transform:uppercase; margin: 20px 0 8px 2px;
}

/* Complete */
.complete-msg {
text-align:center; padding:20px 0; display:none;
animation: fadeIn 0.5s ease both;
}
.complete-msg.show { display:block; }
.complete-msg h2 {
font-family:‘Cinzel’,serif; font-size:20px; color:#d4a843; margin-bottom:6px;
}
.complete-msg p { font-size:13px; color:#8b6a3a; }

/* Reset */
.reset-btn {
display:block; margin:24px auto 0;
background:transparent;
border:1px solid rgba(139,96,32,0.4);
color:#8b6020; font-family:‘Tajawal’,sans-serif;
font-size:12px; padding:8px 24px;
border-radius:50px; cursor:pointer;
transition:all 0.2s; letter-spacing:1px;
}
.reset-btn:hover { border-color:#d4a843; color:#d4a843; }

/* ═══ PANEL ═══ */
.panel-overlay {
position:fixed; inset:0;
background:rgba(0,0,0,0.75);
z-index:100; display:none;
align-items:flex-end;
}
.panel-overlay.open { display:flex; }
.panel {
background: linear-gradient(160deg,#2a1a08,#1a0e05);
border-top:3px solid #d4a843;
border-radius:24px 24px 0 0;
width:100%; max-width:520px; margin:0 auto;
padding:24px 20px 44px;
max-height:85vh; overflow-y:auto;
animation:slideUp 0.35s cubic-bezier(.4,0,.2,1);
position:relative;
}
@keyframes slideUp { from{transform:translateY(100%)} to{transform:translateY(0)} }
.panel-close {
position:absolute; top:14px; left:16px;
background:rgba(255,255,255,0.08);
border:1px solid rgba(255,255,255,0.1);
color:#aaa; font-size:16px;
width:30px; height:30px; border-radius:50%;
cursor:pointer; display:flex; align-items:center; justify-content:center;
}
.panel-time { font-size:11px; color:#d4a843; letter-spacing:2px; margin-bottom:4px; }
.panel-title { font-size:21px; font-weight:900; color:#f5e8c8; margin-bottom:6px; }
.panel-emoji-row { font-size:26px; margin-bottom:14px; }
.sblock {
background:rgba(255,255,255,0.04);
border:1px solid rgba(212,168,67,0.15);
border-radius:14px; padding:14px; margin-bottom:10px;
}
.sblock h3 { font-size:11px; color:#d4a843; letter-spacing:2px; text-transform:uppercase; margin-bottom:10px; }
.sblock p, .sblock li { font-size:13px; color:#c8b090; line-height:1.8; }
.sblock ul { padding-right:16px; }
.sblock li { margin-bottom:4px; }
.tip-row { display:flex; align-items:flex-start; gap:8px; margin-bottom:6px; }
.tip-icon { font-size:15px; min-width:20px; }
.tip-text { font-size:13px; color:#c8b090; line-height:1.6; }
.tag {
display:inline-block;
background:rgba(212,168,67,0.12);
border:1px solid rgba(212,168,67,0.25);
color:#d4a843; font-size:11px;
padding:3px 10px; border-radius:50px;
margin:3px 3px 3px 0;
}
.panel::-webkit-scrollbar { width:3px; }
.panel::-webkit-scrollbar-thumb { background:#5a3e1b; border-radius:10px; }

@keyframes fadeIn { from{opacity:0} to{opacity:1} }
</style>

</head>
